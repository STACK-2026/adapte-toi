---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { siteConfig } from "../../../site.config";
import { fullUrl } from "../../utils/config";
import { jsonLdBreadcrumbs } from "../../utils/seo";

const breadcrumbs = [
  { name: "Accueil", url: siteConfig.url },
  { name: "Guides", url: fullUrl("/guides") },
];

const guides = [
  { title: "Guide complet de la reconversion professionnelle a l'ere de l'IA", description: "Tout comprendre pour prendre les bonnes decisions face a la transformation IA du marche du travail.", category: "reconversion", words: "5 000+" },
  { title: "Se former a l'IA gratuitement en 2026", description: "Les meilleures ressources gratuites pour monter en competences IA, meme sans background technique.", category: "formation", words: "3 500+" },
  { title: "Devenir freelance IA : le guide pratique", description: "Comment transformer les competences IA en activite independante rentable.", category: "freelance-ia", words: "4 000+" },
  { title: "Tes etudes ne servent plus a rien ? Ce que tu peux faire maintenant", description: "Guide pour les etudiants et jeunes diplomes face a l'obsolescence des formations classiques.", category: "reconversion", words: "3 000+" },
  { title: "Financer ta formation IA avec le CPF", description: "Tout sur le financement public de la reconversion : CPF, AIF, POEI, contrat pro.", category: "formation", words: "2 500+" },
  { title: "Prompt engineering pour debutants", description: "Apprendre a formuler des prompts efficaces pour ChatGPT, Claude et les autres.", category: "outils-ia", words: "3 000+" },
  { title: "Automatiser ton travail avec l'IA : guide pratique", description: "Make, Zapier, Claude, GPT : comment automatiser les taches repetitives de ton job.", category: "outils-ia", words: "3 500+" },
  { title: "Negocier ton salaire avec des competences IA", description: "+25% de salaire moyen pour les profils IA-ready (PwC). Comment en profiter.", category: "reconversion", words: "2 500+" },
];
---

<BaseLayout
  title={`Guides pratiques | ${siteConfig.name}`}
  description="Guides complets et actionables pour te reconvertir, te former a l'IA, ou booster ta carriere. Zero bullshit, que du concret."
  jsonLd={jsonLdBreadcrumbs(breadcrumbs)}
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <Breadcrumbs items={breadcrumbs} />

    <h1 class="mb-4">Guides pratiques</h1>
    <p class="text-gray-600 text-lg mb-10 max-w-3xl">
      Des guides de fond, 2 500 a 5 000+ mots, ecrits pour te donner un plan d'action clair. Pas de survol, pas de bullshit.
    </p>

    <div class="space-y-6">
      {guides.map((guide) => (
        <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
          <div class="flex items-start justify-between gap-4">
            <div>
              <span class="text-xs font-medium text-primary uppercase tracking-wide">{guide.category}</span>
              <h3 class="font-bold text-lg mt-1 mb-2">{guide.title}</h3>
              <p class="text-gray-500 text-sm">{guide.description}</p>
            </div>
            <span class="text-xs text-gray-400 whitespace-nowrap mt-1">{guide.words} mots</span>
          </div>
          <p class="text-gray-400 text-sm italic mt-3">Bientot disponible</p>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
