---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../../../site.config";
import { fullUrl } from "../../utils/config";
import { jsonLdBreadcrumbs } from "../../utils/seo";

const breadcrumbs = [
  { name: "Accueil", url: siteConfig.url },
  { name: "Guides", url: fullUrl("/guides") },
];

const publishedGuides = (await getCollection("guides", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const upcoming = [
  { title: "Guide complet de la reconversion professionnelle à l'ère de l'IA", category: "reconversion", words: "5 000+" },
  { title: "Devenir freelance grâce à l'IA : le guide ultime", category: "freelance-ia", words: "4 000+" },
  { title: "Tes études ne servent plus à rien ? Ce que tu peux faire", category: "reconversion", words: "3 000+" },
  { title: "Automatiser ton travail avec l'IA : guide pratique", category: "outils-ia", words: "3 500+" },
  { title: "Négocier ton salaire avec des compétences IA", category: "reconversion", words: "2 500+" },
];
---

<BaseLayout
  title={`Guides pratiques | ${siteConfig.name}`}
  description="Guides complets et gratuits pour te reconvertir, te former à l'IA, ou booster ta carrière. Zéro bullshit, que du concret."
  jsonLd={jsonLdBreadcrumbs(breadcrumbs)}
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <Breadcrumbs items={breadcrumbs} />

    <h1 class="mb-4">Guides pratiques</h1>
    <p class="text-gray-600 text-lg mb-10 max-w-3xl">
      Des guides de fond, 2 500 à 5 000+ mots, écrits pour te donner un plan d'action clair. Gratuits, sans inscription. Pas de survol, pas de bullshit.
    </p>

    {/* Published guides */}
    {publishedGuides.length > 0 && (
      <div class="mb-12">
        <h2 class="text-xl font-bold mb-6">Disponibles</h2>
        <div class="space-y-4">
          {publishedGuides.map((guide) => (
            <a href={`/guides/${guide.id}`} class="block bg-white rounded-2xl p-6 border border-gray-100 shadow-sm hover-glow hover-shine transition-all hover:-translate-y-1">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <span class="text-xs font-medium text-primary uppercase tracking-wide">{guide.data.category}</span>
                  <h3 class="font-bold text-lg mt-1 mb-2">{guide.data.title}</h3>
                  <p class="text-gray-500 text-sm">{guide.data.description}</p>
                </div>
                <div class="flex-shrink-0 text-right">
                  {guide.data.readingTime && <span class="text-xs text-gray-400 block">{guide.data.readingTime}</span>}
                  <span class="text-primary text-sm font-semibold mt-1 block">Lire &rarr;</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    {/* Upcoming */}
    <div>
      <h2 class="text-xl font-bold mb-6">Bientôt disponibles</h2>
      <div class="space-y-4">
        {upcoming.map((guide) => (
          <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm opacity-60">
            <div class="flex items-start justify-between gap-4">
              <div>
                <span class="text-xs font-medium text-primary uppercase tracking-wide">{guide.category}</span>
                <h3 class="font-bold text-lg mt-1 mb-2">{guide.title}</h3>
              </div>
              <span class="text-xs text-gray-400 whitespace-nowrap">{guide.words} mots</span>
            </div>
            <p class="text-gray-400 text-sm italic">En préparation</p>
          </div>
        ))}
      </div>
    </div>

    <div class="text-center mt-12 p-8 bg-gray-50 rounded-2xl">
      <p class="text-gray-600 mb-4">
        Abonne-toi à la newsletter pour être prévenu des nouveaux guides.
      </p>
      <a href="/newsletter" class="text-primary font-semibold hover:underline">
        S'abonner au Signal &rarr;
      </a>
    </div>
  </div>
</BaseLayout>
