---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DiagnosticQuiz from "../../components/DiagnosticQuiz.astro";
import { siteConfig } from "../../../site.config";

const title = "Diagnostic IA : ton métier est-il menacé ? | Adapte-toi";
const description = "5 questions, 1 minute. Évalue gratuitement l'impact de l'IA sur ton métier. Sans inscription, sans email, sans formation à vendre.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Quiz",
    name: "Diagnostic IA : ton métier est-il menacé ?",
    description,
    educationalLevel: "Professional",
    numberOfQuestions: 5,
    about: {
      "@type": "Thing",
      name: "Impact de l'intelligence artificielle sur l'emploi",
    },
    isPartOf: {
      "@type": "WebSite",
      name: siteConfig.name,
      url: siteConfig.url,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "Diagnostic Adapte-toi",
    url: `${siteConfig.url}/diagnostic`,
    applicationCategory: "BusinessApplication",
    applicationSubCategory: "Career assessment",
    operatingSystem: "Any (web)",
    inLanguage: "fr-FR",
    description: "Outil interactif qui évalue en 5 questions l'exposition d'un métier à l'automatisation par l'IA. Sans inscription, sans email.",
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "EUR",
    },
    featureList: [
      "5 questions pondérées",
      "Score sur 15 avec 4 profils de résilience",
      "Ressources personnalisées selon le score",
      "Sans inscription ni email",
    ],
    aggregateRating: undefined,
    publisher: {
      "@type": "Organization",
      name: siteConfig.name,
      url: siteConfig.url,
    },
  },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <div class="max-w-3xl mx-auto px-4 py-12 md:py-20">
    <div class="text-center mb-10">
      <span class="inline-flex items-center gap-2 bg-primary/8 text-primary text-xs sm:text-sm font-semibold px-3 sm:px-4 py-1.5 rounded-full mb-4 sm:mb-6 scale-reveal">
        <span class="w-1.5 h-1.5 sm:w-2 sm:h-2 bg-primary rounded-full pulse-signal"></span>
        Diagnostic gratuit, 1 minute
      </span>
      <h1 class="text-3xl md:text-5xl mb-4 blur-reveal" data-speakable>
        Ton métier est-il menacé par l'IA ?
      </h1>
      <p class="text-gray-500 text-base md:text-lg max-w-xl mx-auto blur-reveal" data-speakable>
        5 questions. 1 minute. Zéro inscription, zéro email. Tu obtiens un score personnalisé et les ressources gratuites qui correspondent à ta situation.
      </p>
    </div>

    <DiagnosticQuiz />

    <div class="mt-12 text-center">
      <p class="text-sm text-gray-400 mb-3">Tu préfères lire la fiche de ton métier directement ?</p>
      <div class="flex flex-wrap gap-2 justify-center">
        <a href="/metiers" class="inline-flex items-center gap-1.5 bg-gray-50 text-gray-700 text-sm font-medium px-4 py-2 rounded-full border border-gray-200 hover:border-primary/30 hover:text-primary transition-all">
          25 fiches métier
        </a>
        <a href="/guides" class="inline-flex items-center gap-1.5 bg-gray-50 text-gray-700 text-sm font-medium px-4 py-2 rounded-full border border-gray-200 hover:border-primary/30 hover:text-primary transition-all">
          Guides de reconversion
        </a>
        <a href="/outils" class="inline-flex items-center gap-1.5 bg-gray-50 text-gray-700 text-sm font-medium px-4 py-2 rounded-full border border-gray-200 hover:border-primary/30 hover:text-primary transition-all">
          Annuaire d'outils IA
        </a>
      </div>
    </div>

    <section class="mt-20 border-t border-gray-100 pt-12">
      <h2 class="text-xl md:text-2xl font-display font-bold mb-6">Comment on calcule ton score</h2>
      <div class="prose prose-sm max-w-none text-gray-600">
        <p>
          Le diagnostic s'appuie sur les 5 facteurs que les études (OCDE, Anthropic, McKinsey, PwC) identifient comme déterminants face à l'automatisation : répétitivité des tâches, différenciation humaine, maîtrise des outils IA, relations humaines, et capacité d'adaptation.
        </p>
        <p>
          Chaque question vaut de 0 à 3 points. Ton score total (sur 15) te place dans l'un des quatre profils : <strong>en danger</strong> (0-4), <strong>en mutation</strong> (5-8), <strong>bien positionné</strong> (9-12), <strong>prêt pour demain</strong> (13-15).
        </p>
        <p>
          Ce diagnostic n'est pas un oracle. Il te donne un premier repère et t'oriente vers les bonnes ressources. Pour une analyse plus fine, lis la <a href="/metiers" class="text-primary font-semibold">fiche de ton métier</a>.
        </p>
      </div>
    </section>
  </div>
</BaseLayout>
