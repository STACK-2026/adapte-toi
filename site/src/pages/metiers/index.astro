---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../../../site.config";
import { fullUrl } from "../../utils/config";
import { jsonLdBreadcrumbs } from "../../utils/seo";

const breadcrumbs = [
  { name: "Accueil", url: siteConfig.url },
  { name: "Fiches métier", url: fullUrl("/metiers") },
];

// Published fiches
const fiches = (await getCollection("metiers", ({ data }) => !data.draft))
  .sort((a, b) => b.data.riskScore - a.data.riskScore);

// Upcoming fiches (not yet written)
const upcoming = [
  { name: "Technicien de maintenance", risk: "faible" },
  { name: "Kinésithérapeute", risk: "faible" },
];

const riskColors: Record<string, { bg: string; text: string; label: string }> = {
  "tres-eleve": { bg: "bg-red-100", text: "text-red-700", label: "Risque très élevé" },
  "eleve": { bg: "bg-orange-100", text: "text-orange-700", label: "Risque élevé" },
  "moyen": { bg: "bg-yellow-100", text: "text-yellow-700", label: "Risque moyen" },
  "faible": { bg: "bg-green-100", text: "text-green-700", label: "Risque faible" },
};
---

<BaseLayout
  title={`Fiches métier IA | ${siteConfig.name}`}
  description="Analyse détaillée de l'impact de l'IA sur 50+ métiers. Decouvre si ton métier est menace, comment il se transforme, et les compétences a acquérir."
  jsonLd={jsonLdBreadcrumbs(breadcrumbs)}
>
  <div class="max-w-6xl mx-auto px-4 py-12">
    <Breadcrumbs items={breadcrumbs} />

    <h1 class="mb-3 sm:mb-4">Fiches métier : quel impact de l'IA sur ta profession ?</h1>
    <p class="text-gray-600 text-base sm:text-lg mb-8 sm:mb-10 max-w-3xl leading-relaxed">
      Pour chaque métier : l'état des lieux de l'impact de l'IA, ce qui change concrètement, les compétences à acquérir, les outils à maîtriser, et un plan d'action. Sources : Anthropic, OCDE, McKinsey, France Travail.
    </p>

    {/* Published fiches */}
    {fiches.length > 0 && (
      <div class="mb-10 sm:mb-12">
        <h2 class="text-lg sm:text-xl font-bold mb-4 sm:mb-6">{fiches.length} fiches disponibles</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
          {fiches.map((fiche) => {
            const risk = riskColors[fiche.data.riskLevel];
            const riskColor = fiche.data.riskScore >= 7 ? '#ef4444' : fiche.data.riskScore >= 5 ? '#f59e0b' : '#22c55e';
            return (
              <a href={`/metiers/${fiche.id}`} class="flex sm:block items-center gap-4 sm:gap-0 bg-white rounded-xl sm:rounded-2xl p-4 sm:p-6 border border-gray-100 shadow-sm hover-glow transition-all active:scale-[0.98] hover:-translate-y-1">
                {/* Mobile: horizontal layout with score prominently */}
                <div class="flex-shrink-0 sm:hidden w-12 h-12 rounded-xl flex items-center justify-center font-display font-bold text-lg text-white" style={`background: ${riskColor};`}>
                  {fiche.data.riskScore}
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center justify-between mb-1 sm:mb-3">
                    <h3 class="font-bold text-base sm:text-lg truncate">{fiche.data.metier}</h3>
                    <span class={`hidden sm:inline-flex text-xs font-medium px-2.5 py-1 rounded-full ${risk.bg} ${risk.text}`}>
                      {fiche.data.riskScore}/10
                    </span>
                  </div>
                  <p class="text-gray-500 text-xs sm:text-sm mb-2 sm:mb-3 line-clamp-1 sm:line-clamp-2">{fiche.data.description}</p>
                  <div class="flex items-center gap-2">
                    <div class="flex-1 bg-gray-200 rounded-full h-1.5 sm:h-2">
                      <div class="h-1.5 sm:h-2 rounded-full transition-all" style={`width: ${fiche.data.riskScore * 10}%; background: ${riskColor};`}></div>
                    </div>
                    <span class="text-xs text-primary font-semibold whitespace-nowrap">Lire &rarr;</span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    )}

    {/* Upcoming fiches */}
    <div>
      <h2 class="text-xl font-bold mb-6">Bientot disponibles</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {upcoming.map((métier) => {
          const risk = riskColors[métier.risk];
          return (
            <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm opacity-70">
              <div class="flex items-center justify-between mb-3">
                <h3 class="font-bold text-lg">{métier.name}</h3>
                <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${risk.bg} ${risk.text}`}>
                  {risk.label}
                </span>
              </div>
              <p class="text-gray-400 text-sm italic">Fiche en préparation</p>
            </div>
          );
        })}
      </div>
    </div>

    <div class="text-center mt-12 p-8 bg-gray-50 rounded-2xl">
      <p class="text-gray-600 mb-4">
        50+ fiches métier en préparation. Abonne-toi à la newsletter pour être prévenu des nouvelles publications.
      </p>
      <a href="/newsletter" class="text-primary font-semibold hover:underline">
        S'abonner au Signal &rarr;
      </a>
    </div>
  </div>
</BaseLayout>
