---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../../../site.config";
import { fullUrl } from "../../utils/config";
import { jsonLdBreadcrumbs } from "../../utils/seo";

const breadcrumbs = [
  { name: "Accueil", url: siteConfig.url },
  { name: "Fiches metier", url: fullUrl("/metiers") },
];

// Published fiches
const fiches = (await getCollection("metiers", ({ data }) => !data.draft))
  .sort((a, b) => b.data.riskScore - a.data.riskScore);

// Upcoming fiches (not yet written)
const upcoming = [
  { name: "Responsable RH / Recruteur", risk: "moyen" },
  { name: "Responsable marketing", risk: "eleve" },
  { name: "Avocat / Juriste", risk: "moyen" },
  { name: "Journaliste", risk: "eleve" },
  { name: "Graphiste / Designer", risk: "eleve" },
  { name: "Assistant administratif", risk: "tres-eleve" },
  { name: "Analyste financier", risk: "eleve" },
  { name: "Enseignant", risk: "faible" },
  { name: "Agent immobilier", risk: "moyen" },
  { name: "Photographe / Videaste", risk: "eleve" },
  { name: "Data analyst", risk: "moyen" },
  { name: "Infirmier / Aide-soignant", risk: "faible" },
];

const riskColors: Record<string, { bg: string; text: string; label: string }> = {
  "tres-eleve": { bg: "bg-red-100", text: "text-red-700", label: "Risque tres eleve" },
  "eleve": { bg: "bg-orange-100", text: "text-orange-700", label: "Risque eleve" },
  "moyen": { bg: "bg-yellow-100", text: "text-yellow-700", label: "Risque moyen" },
  "faible": { bg: "bg-green-100", text: "text-green-700", label: "Risque faible" },
};
---

<BaseLayout
  title={`Fiches metier IA | ${siteConfig.name}`}
  description="Analyse detaillee de l'impact de l'IA sur 50+ metiers. Decouvre si ton metier est menace, comment il se transforme, et les competences a acquerir."
  jsonLd={jsonLdBreadcrumbs(breadcrumbs)}
>
  <div class="max-w-6xl mx-auto px-4 py-12">
    <Breadcrumbs items={breadcrumbs} />

    <h1 class="mb-4">Fiches metier : quel impact de l'IA sur ta profession ?</h1>
    <p class="text-gray-600 text-lg mb-10 max-w-3xl">
      Pour chaque metier : l'etat des lieux de l'impact de l'IA, ce qui change concretement, les competences a acquerir, les outils a maitriser, et un plan d'action. Sources : Anthropic, OCDE, McKinsey, France Travail.
    </p>

    {/* Published fiches */}
    {fiches.length > 0 && (
      <div class="mb-12">
        <h2 class="text-xl font-bold mb-6">Fiches disponibles</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {fiches.map((fiche) => {
            const risk = riskColors[fiche.data.riskLevel];
            return (
              <a href={`/metiers/${fiche.id}`} class="block bg-white rounded-2xl p-6 border border-gray-100 shadow-sm hover:shadow-md transition-all hover:-translate-y-1">
                <div class="flex items-center justify-between mb-3">
                  <h3 class="font-bold text-lg">{fiche.data.metier}</h3>
                  <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${risk.bg} ${risk.text}`}>
                    {fiche.data.riskScore}/10
                  </span>
                </div>
                <p class="text-gray-500 text-sm mb-3 line-clamp-2">{fiche.data.description}</p>
                <div class="flex items-center gap-2">
                  <div class="flex-1 bg-gray-200 rounded-full h-2">
                    <div
                      class="h-2 rounded-full"
                      style={`width: ${fiche.data.riskScore * 10}%; background: ${fiche.data.riskScore >= 7 ? '#ef4444' : fiche.data.riskScore >= 5 ? '#f59e0b' : '#22c55e'};`}
                    ></div>
                  </div>
                  <span class="text-xs text-primary font-semibold">Lire &rarr;</span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    )}

    {/* Upcoming fiches */}
    <div>
      <h2 class="text-xl font-bold mb-6">Bientot disponibles</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {upcoming.map((metier) => {
          const risk = riskColors[metier.risk];
          return (
            <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm opacity-70">
              <div class="flex items-center justify-between mb-3">
                <h3 class="font-bold text-lg">{metier.name}</h3>
                <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${risk.bg} ${risk.text}`}>
                  {risk.label}
                </span>
              </div>
              <p class="text-gray-400 text-sm italic">Fiche en preparation</p>
            </div>
          );
        })}
      </div>
    </div>

    <div class="text-center mt-12 p-8 bg-gray-50 rounded-2xl">
      <p class="text-gray-600 mb-4">
        50+ fiches metier en preparation. Abonne-toi a la newsletter pour etre prevenu des nouvelles publications.
      </p>
      <a href="/newsletter" class="text-primary font-semibold hover:underline">
        S'abonner au Signal &rarr;
      </a>
    </div>
  </div>
</BaseLayout>
