---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { getCollection, render } from "astro:content";
import { siteConfig } from "../../../site.config";
import { fullUrl } from "../../utils/config";
import { jsonLdArticle, jsonLdBreadcrumbs, jsonLdFaq, jsonLdItemList } from "../../utils/seo";

export async function getStaticPaths() {
  const fiches = await getCollection("metiers", ({ data }) => !data.draft);
  return fiches.map((fiche) => ({
    params: { slug: fiche.id },
    props: { fiche, allFiches: fiches },
  }));
}

const { fiche, allFiches } = Astro.props;
const { Content } = await render(fiche);

// Related fiches: same sector first, then closest risk score
const otherFiches = allFiches
  .filter((f) => f.id !== fiche.id)
  .sort((a, b) => {
    const sameA = a.data.sector === fiche.data.sector ? -10 : 0;
    const sameB = b.data.sector === fiche.data.sector ? -10 : 0;
    const distA = Math.abs(a.data.riskScore - fiche.data.riskScore);
    const distB = Math.abs(b.data.riskScore - fiche.data.riskScore);
    return (sameA + distA) - (sameB + distB);
  });

const ficheUrl = fullUrl(`/metiers/${fiche.id}`);
const dateStr = fiche.data.date.toISOString().split("T")[0];

const breadcrumbs = [
  { name: "Accueil", url: siteConfig.url },
  { name: "Fiches métier", url: fullUrl("/metiers") },
  { name: fiche.data.metier, url: ficheUrl },
];

const riskColors: Record<string, { bg: string; text: string; label: string }> = {
  "tres-eleve": { bg: "bg-red-100", text: "text-red-700", label: "Risque très élevé" },
  "eleve": { bg: "bg-orange-100", text: "text-orange-700", label: "Risque élevé" },
  "moyen": { bg: "bg-yellow-100", text: "text-yellow-700", label: "Risque moyen" },
  "faible": { bg: "bg-green-100", text: "text-green-700", label: "Risque faible" },
};

const risk = riskColors[fiche.data.riskLevel];

const jsonLd: any[] = [
  jsonLdArticle({
    title: fiche.data.title,
    description: fiche.data.description,
    url: ficheUrl,
    datePublished: dateStr,
    author: fiche.data.author || siteConfig.blog.defaultAuthor,
    keywords: fiche.data.keywords?.split(",").map((k: string) => k.trim()),
  }),
  jsonLdBreadcrumbs(breadcrumbs),
];

if (fiche.data.faq && fiche.data.faq.length > 0) {
  jsonLd.push(jsonLdFaq(fiche.data.faq));
}

if (fiche.data.relatedTools && fiche.data.relatedTools.length > 0) {
  jsonLd.push(jsonLdItemList({
    name: `Outils IA recommandés pour ${fiche.data.metier}`,
    description: `Top outils IA à connaître pour le métier de ${fiche.data.metier} en 2026`,
    url: ficheUrl,
    items: fiche.data.relatedTools.map(t => ({
      name: t.name,
      url: t.url.startsWith("http") ? t.url : fullUrl(t.url),
    })),
  }));
}
---

<BaseLayout
  title={`${fiche.data.title} | ${siteConfig.name}`}
  description={fiche.data.description}
  canonicalUrl={ficheUrl}
  ogImage={fiche.data.image ?? `/og/metiers/${fiche.id}.png`}
  ogType="article"
  publishedTime={dateStr}
  jsonLd={jsonLd}
>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <Breadcrumbs items={breadcrumbs} />

    <header class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-xs font-medium text-gray-500 uppercase tracking-wide">{fiche.data.sector}</span>
        <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${risk.bg} ${risk.text}`}>
          {risk.label}
        </span>
      </div>
      <h1 class="mb-4">{fiche.data.title}</h1>

      <!-- Risk score visual -->
      <div class="flex items-center gap-4 mb-6 p-4 bg-gray-50 rounded-xl">
        <div class="text-center">
          <div class="font-display font-bold text-4xl" style={`color: var(--color-primary);`}>{fiche.data.riskScore}/10</div>
          <div class="text-xs text-gray-500 mt-1">Score d'impact IA</div>
        </div>
        <div class="flex-1">
          <div class="w-full bg-gray-200 rounded-full h-3">
            <div
              class="h-3 rounded-full transition-all"
              style={`width: ${fiche.data.riskScore * 10}%; background: ${fiche.data.riskScore >= 7 ? '#ef4444' : fiche.data.riskScore >= 5 ? '#f59e0b' : '#22c55e'};`}
            ></div>
          </div>
        </div>
      </div>

      <div class="flex flex-wrap items-center gap-4 text-gray-500 text-sm">
        <span>{fiche.data.author || siteConfig.blog.defaultAuthor}</span>
        <span>·</span>
        <time datetime={dateStr}>
          {fiche.data.date.toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}
        </time>
        {fiche.data.lastReviewed && (
          <>
            <span>·</span>
            <span>Revu le {fiche.data.lastReviewed.toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}</span>
          </>
        )}
      </div>
    </header>

    {fiche.data.image && (
      <figure class="mb-10">
        <img
          src={fiche.data.image}
          alt={fiche.data.imageAlt || fiche.data.title}
          class="w-full rounded-xl"
          loading="eager"
          width="800"
          height="450"
        />
      </figure>
    )}

    <!-- Table des matières sticky (auto-générée par JS) -->
    <nav id="fiche-toc" class="hidden sm:block sticky top-24 float-right -mr-48 w-40 ml-8 mb-8 text-xs" aria-label="Table des matières">
      <p class="font-bold text-gray-400 uppercase tracking-wider mb-3 text-[10px]">Sommaire</p>
      <ul id="fiche-toc-list" class="space-y-2 border-l-2 border-gray-100 pl-3"></ul>
    </nav>

    <div class="prose max-w-none" id="fiche-content">
      <Content />
    </div>

    <script>
      // Auto-generate TOC from H2s in fiche content
      const content = document.getElementById("fiche-content");
      const tocList = document.getElementById("fiche-toc-list");
      const toc = document.getElementById("fiche-toc");
      if (content && tocList) {
        const h2s = content.querySelectorAll("h2");
        if (h2s.length >= 3) {
          h2s.forEach((h2, i) => {
            const id = h2.id || `section-${i}`;
            h2.id = id;
            const li = document.createElement("li");
            li.innerHTML = `<a href="#${id}" class="text-gray-400 hover:text-primary transition-colors block py-0.5 leading-tight">${h2.textContent}</a>`;
            tocList.appendChild(li);
          });
          // Show TOC only if enough space (wide screens)
          if (window.innerWidth >= 1280 && toc) {
            toc.classList.remove("hidden");
            toc.classList.add("block");
          }
        }
      }
    </script>

    <!-- Maillage interne : guides liés -->
    <div class="mt-12 p-5 sm:p-6 bg-gray-50 rounded-2xl">
      <p class="font-bold text-base sm:text-lg mb-4">Passe à l'action</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <a href="/guides/reconversion-ia-guide-complet" class="flex items-center gap-3 p-3 bg-white rounded-xl border border-gray-100 hover:border-primary/30 transition-colors text-sm">
          <span class="text-primary font-bold text-lg">📖</span>
          <span class="text-gray-700 font-medium">Guide reconversion IA</span>
        </a>
        <a href="/guides/se-former-ia-gratuitement" class="flex items-center gap-3 p-3 bg-white rounded-xl border border-gray-100 hover:border-primary/30 transition-colors text-sm">
          <span class="text-primary font-bold text-lg">🎓</span>
          <span class="text-gray-700 font-medium">Se former gratuitement</span>
        </a>
        <a href="/guides/prompt-engineering-debutant" class="flex items-center gap-3 p-3 bg-white rounded-xl border border-gray-100 hover:border-primary/30 transition-colors text-sm">
          <span class="text-primary font-bold text-lg">💡</span>
          <span class="text-gray-700 font-medium">Apprendre le prompt</span>
        </a>
        <a href="/guides/financer-formation-ia-cpf" class="flex items-center gap-3 p-3 bg-white rounded-xl border border-gray-100 hover:border-primary/30 transition-colors text-sm">
          <span class="text-primary font-bold text-lg">💰</span>
          <span class="text-gray-700 font-medium">Financer avec le CPF</span>
        </a>
        <a href="/outils/chatgpt" class="flex items-center gap-3 p-3 bg-white rounded-xl border border-gray-100 hover:border-primary/30 transition-colors text-sm">
          <span class="text-primary font-bold text-lg">🤖</span>
          <span class="text-gray-700 font-medium">Guide ChatGPT</span>
        </a>
        <a href="/outils/claude" class="flex items-center gap-3 p-3 bg-white rounded-xl border border-gray-100 hover:border-primary/30 transition-colors text-sm">
          <span class="text-primary font-bold text-lg">🧠</span>
          <span class="text-gray-700 font-medium">Guide Claude</span>
        </a>
      </div>
    </div>

    <!-- Fiches métier liées -->
    {otherFiches.length > 0 && (
      <div class="mt-8">
        <p class="font-bold text-base mb-4">Fiches métier similaires</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          {otherFiches.slice(0, 3).map((f) => (
            <a href={`/metiers/${f.id}`} class="flex items-center gap-3 p-3 bg-white rounded-xl border border-gray-100 hover:border-primary/30 transition-colors text-sm">
              <span class="font-display font-bold text-primary">{f.data.riskScore}/10</span>
              <span class="text-gray-700 font-medium truncate">{f.data.metier}</span>
            </a>
          ))}
        </div>
        <a href="/metiers" class="inline-block mt-4 text-primary text-sm font-semibold hover:underline">Voir les 25 fiches métier &rarr;</a>
      </div>
    )}
  </article>
</BaseLayout>
