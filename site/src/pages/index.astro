---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Problem from "../components/Problem.astro";
import Stats from "../components/Stats.astro";
import Features from "../components/Features.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Newsletter from "../components/Newsletter.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import BlogCard from "../components/BlogCard.astro";
import { siteConfig } from "../../site.config";
import { jsonLdHomepage } from "../utils/seo";
import { getCollection } from "astro:content";

const recentPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title={`${siteConfig.name} - ${siteConfig.tagline}`}
  description={siteConfig.description}
  jsonLd={jsonLdHomepage()}
>
  {/* 1. Hero - accroche + CTA */}
  <Hero />

  {/* 2. Probleme - les chiffres choc */}
  <Problem />

  {/* 3. Stats - données sourcées */}
  <Stats />

  {/* 4. Features - ce qu'on propose */}
  <Features />

  {/* 5. Comment ça marche */}
  <HowItWorks />

  {/* 6. Témoignage / social proof */}
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto text-center fade-up">
      <h2 class="mb-8">Ils se sont adaptés</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <blockquote class="bg-white rounded-2xl p-8 text-left border border-gray-100 shadow-sm">
          <p class="text-gray-700 mb-4 italic">
            "J'etais chef de projet IT depuis 12 ans. Quand j'ai vu les chiffres d'Anthropic sur la baisse des offres dans mon domaine, j'ai compris qu'il fallait bouger. Grace aux guides d'Adapte-toi, je me suis forme au prompt engineering et j'ai lance mon activité de consultant IA."
          </p>
          <footer class="text-sm">
            <span class="font-semibold text-secondary">Marc, 41 ans</span>
            <span class="text-gray-400"> - Ex-chef de projet IT, aujourd'hui consultant IA</span>
          </footer>
        </blockquote>
        <blockquote class="bg-white rounded-2xl p-8 text-left border border-gray-100 shadow-sm">
          <p class="text-gray-700 mb-4 italic">
            "En deuxieme année de communication, je me demandais si ça valait le coup de continuer. Adapte-toi m'a aide à comprendre quelles compétences ajouter a ma formation pour rester pertinente. Aujourd'hui je maîtrise les outils IA et je suis plus bankable que mes profs."
          </p>
          <footer class="text-sm">
            <span class="font-semibold text-secondary">Ines, 23 ans</span>
            <span class="text-gray-400"> - Etudiante en communication, spécialisée IA</span>
          </footer>
        </blockquote>
      </div>
      <a href="/temoignages" class="inline-block mt-8 text-primary font-semibold hover:underline">
        Voir tous les témoignages &rarr;
      </a>
    </div>
  </section>

  {/* 7. Blog preview */}
  {recentPosts.length > 0 && (
    <section class="py-20 px-4">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-center justify-between mb-8 fade-up">
          <h2>{siteConfig.blog.name} - Derniers articles</h2>
          <a href="/blog" class="text-primary font-semibold text-sm hover:underline hidden sm:inline">
            Tous les articles &rarr;
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {recentPosts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              slug={post.id}
              image={post.data.image}
              imageAlt={post.data.imageAlt}
              category={post.data.category}
            />
          ))}
        </div>
        <div class="text-center mt-8 sm:hidden">
          <a href="/blog" class="text-primary font-semibold hover:underline">
            Tous les articles &rarr;
          </a>
        </div>
      </div>
    </section>
  )}

  {/* 8. Newsletter */}
  <Newsletter />

  {/* 9. FAQ */}
  <FAQ />

  {/* 10. CTA final */}
  <CTA />
</BaseLayout>
