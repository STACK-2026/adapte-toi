---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { siteConfig } from "../../../site.config";
import { fullUrl } from "../../utils/config";
import { jsonLdBreadcrumbs } from "../../utils/seo";

const breadcrumbs = [
  { name: "Accueil", url: siteConfig.url },
  { name: "Témoignages", url: fullUrl("/temoignages") },
];
---

<BaseLayout
  title={`Témoignages de reconversion | ${siteConfig.name}`}
  description="Des histoires de reconversion professionnelle réussies face à l'IA. Avant/apres, retours d'expérience, conseils concrets."
  jsonLd={jsonLdBreadcrumbs(breadcrumbs)}
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <Breadcrumbs items={breadcrumbs} />

    <h1 class="mb-4">Témoignages</h1>
    <p class="text-gray-600 text-lg mb-10 max-w-3xl">
      Des histoires de reconversion réussies. Des avant/apres concrets. Pour prouver que c'est possible.
    </p>

    <div class="text-center py-20 bg-gray-50 rounded-2xl">
      <p class="text-gray-400 text-lg mb-4">Les premiers témoignages arrivent bientot.</p>
      <p class="text-gray-500 text-sm mb-6">Tu t'es reconverti grace à l'IA ? Partage ton histoire.</p>
      <a
        href={`mailto:${siteConfig.legal.email}?subject=Mon témoignage de reconversion`}
        class="inline-flex items-center gap-2 text-primary font-semibold hover:underline"
      >
        Envoyer ton témoignage &rarr;
      </a>
    </div>
  </div>
</BaseLayout>
