---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogCard from "../../components/BlogCard.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../../../site.config";
import { fullUrl } from "../../utils/config";
import { jsonLdBreadcrumbs } from "../../utils/seo";

const posts = (await getCollection("blog", ({ data }) => !data.draft && data.category === "actu-emploi"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const breadcrumbs = [
  { name: "Accueil", url: siteConfig.url },
  { name: "Actualités", url: fullUrl("/actu") },
];
---

<BaseLayout
  title={`Actualités IA et emploi | ${siteConfig.name}`}
  description="L'actualité de l'intelligence artificielle et son impact sur l'emploi en France et en Europe. Etudes, rapports, analyses."
  jsonLd={jsonLdBreadcrumbs(breadcrumbs)}
>
  <div class="max-w-6xl mx-auto px-4 py-12">
    <Breadcrumbs items={breadcrumbs} />

    <h1 class="mb-4">Actualités IA et emploi</h1>
    <p class="text-gray-600 text-lg mb-10 max-w-3xl">
      Veille hebdomadaire sur l'impact de l'IA sur le marche du travail. Etudes, chiffres, tendances.
    </p>

    {posts.length === 0 ? (
      <div class="text-center py-20">
        <p class="text-gray-400 text-lg mb-4">Les premières actus arrivent bientot.</p>
        <a href="/newsletter" class="text-primary font-semibold hover:underline">
          S'abonner au Signal pour ne rien rater &rarr;
        </a>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            slug={post.id}
            image={post.data.image}
            imageAlt={post.data.imageAlt}
            category={post.data.category}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
