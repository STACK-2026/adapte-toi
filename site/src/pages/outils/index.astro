---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../../../site.config";
import { fullUrl } from "../../utils/config";
import { jsonLdBreadcrumbs } from "../../utils/seo";

const breadcrumbs = [
  { name: "Accueil", url: siteConfig.url },
  { name: "Outils IA", url: fullUrl("/outils") },
];

const publishedOutils = (await getCollection("outils", ({ data }) => !data.draft))
  .sort((a, b) => (b.data.rating || 0) - (a.data.rating || 0));

const categories = [...new Set(publishedOutils.map((o) => o.data.category))];

const upcoming: { name: string; category: string }[] = [];
---

<BaseLayout
  title={`Annuaire d'outils IA | ${siteConfig.name}`}
  description="Les meilleurs outils IA classés par métier et par usage. Tests, comparatifs, liens directs. Gratuit."
  jsonLd={jsonLdBreadcrumbs(breadcrumbs)}
>
  <div class="max-w-6xl mx-auto px-4 py-12">
    <Breadcrumbs items={breadcrumbs} />

    <h1 class="mb-3 sm:mb-4">Annuaire d'outils IA</h1>
    <p class="text-gray-600 text-base sm:text-lg mb-6 sm:mb-10 max-w-3xl leading-relaxed">
      Les meilleurs outils IA, testés et classés par usage. Fiches détaillées, cas d'usage par métier, prix, alternatives. Gratuit.
    </p>

    {/* Published outils */}
    {publishedOutils.length > 0 && (
      <div class="mb-10 sm:mb-16">
        {categories.map((cat) => {
          const outilsInCat = publishedOutils.filter((o) => o.data.category === cat);
          return (
            <div class="mb-8 sm:mb-10">
              <h2 class="text-base sm:text-lg font-bold mb-3 sm:mb-4 text-secondary">{cat}</h2>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-5">
                {outilsInCat.map((outil) => (
                  <a href={`/outils/${outil.id}`} class="flex sm:block items-center gap-3 sm:gap-0 bg-white rounded-xl sm:rounded-2xl p-4 sm:p-6 border border-gray-100 shadow-sm hover-glow transition-all active:scale-[0.98] hover:-translate-y-1">
                    <div class="flex items-center justify-between sm:mb-3 flex-1 min-w-0">
                      <h3 class="font-bold text-sm sm:text-lg truncate">{outil.data.outil}</h3>
                      {outil.data.rating && (
                        <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-accent/10 text-accent">{outil.data.rating}/10</span>
                      )}
                    </div>
                    <p class="text-gray-500 text-xs sm:text-sm mb-2 sm:mb-3 line-clamp-1 sm:line-clamp-2 hidden sm:block">{outil.data.description}</p>
                    <div class="flex items-center justify-between">
                      <span class="text-[10px] sm:text-xs text-gray-400">{outil.data.pricing.split("·")[0]}</span>
                      <span class="text-primary text-xs sm:text-sm font-semibold">Lire &rarr;</span>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          );
        })}
      </div>
    )}

    {/* Upcoming */}
    <div>
      <h2 class="text-xl font-bold mb-6">Bientôt disponibles</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
        {upcoming.map((o) => (
          <div class="bg-white rounded-xl p-4 border border-gray-100 shadow-sm opacity-60 text-center">
            <p class="font-bold text-sm">{o.name}</p>
            <p class="text-xs text-gray-400 mt-1">{o.category}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="text-center mt-12 p-8 bg-gray-50 rounded-2xl">
      <p class="text-gray-600 mb-4">
        20+ fiches outils en préparation. Abonne-toi pour être prévenu.
      </p>
      <a href="/newsletter" class="text-primary font-semibold hover:underline">
        S'abonner au Signal &rarr;
      </a>
    </div>
  </div>
</BaseLayout>
