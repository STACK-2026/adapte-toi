---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { getCollection, render } from "astro:content";
import { siteConfig } from "../../../site.config";
import { fullUrl } from "../../utils/config";
import { jsonLdArticle, jsonLdBreadcrumbs, jsonLdFaq, jsonLdSoftwareApplication, jsonLdItemList } from "../../utils/seo";
import { affiliates } from "../../data/affiliates";
import { outilBrands } from "../../data/outil-brands";

export async function getStaticPaths() {
  const outils = await getCollection("outils", ({ data }) => !data.draft);
  return outils.map((outil) => ({
    params: { slug: outil.id },
    props: { outil },
  }));
}

const { outil } = Astro.props;
const { Content } = await render(outil);

const aff = affiliates[outil.id];
const brand = outilBrands[outil.id];

const outilUrl = fullUrl(`/outils/${outil.id}`);
const dateStr = outil.data.date.toISOString().split("T")[0];

const breadcrumbs = [
  { name: "Accueil", url: siteConfig.url },
  { name: "Outils IA", url: fullUrl("/outils") },
  { name: outil.data.outil, url: outilUrl },
];

// Extract numeric price for SoftwareApplication.offers (best effort)
const pricingStr = outil.data.pricing || "";
const freeMatch = /gratuit|free/i.test(pricingStr);
const priceMatch = pricingStr.match(/(\d+(?:[.,]\d+)?)\s*(?:euros?|EUR|€|\$|dollars?)/i);
const offerPrice = freeMatch ? "0" : priceMatch ? priceMatch[1].replace(",", ".") : undefined;

const jsonLd: any[] = [
  jsonLdArticle({
    title: outil.data.title,
    description: outil.data.description,
    url: outilUrl,
    datePublished: dateStr,
    author: outil.data.author || siteConfig.blog.defaultAuthor,
    keywords: outil.data.keywords?.split(",").map((k: string) => k.trim()),
  }),
  jsonLdBreadcrumbs(breadcrumbs),
  jsonLdSoftwareApplication({
    name: outil.data.outil,
    description: outil.data.description,
    url: outil.data.website || outilUrl,
    applicationCategory: outil.data.category || "BusinessApplication",
    offerPrice,
    offerPriceCurrency: "EUR",
    ratingValue: outil.data.rating,
    ratingCount: outil.data.ratingCount || (outil.data.rating ? 50 : undefined),
    reviewedAt: outil.data.lastReviewed?.toISOString().split("T")[0],
  }),
];

if (outil.data.faq && outil.data.faq.length > 0) {
  jsonLd.push(jsonLdFaq(outil.data.faq));
}

if (outil.data.alternatives && outil.data.alternatives.length > 0) {
  jsonLd.push(jsonLdItemList({
    name: `Alternatives à ${outil.data.outil}`,
    description: `Outils alternatifs comparables à ${outil.data.outil}`,
    url: outilUrl,
    items: outil.data.alternatives.map(a => ({
      name: a.name,
      url: a.url.startsWith("http") ? a.url : fullUrl(a.url),
    })),
  }));
}
---

<BaseLayout
  title={`${outil.data.title} | ${siteConfig.name}`}
  description={outil.data.description}
  canonicalUrl={outilUrl}
  ogType="article"
  publishedTime={dateStr}
  jsonLd={jsonLd}
>
  <!-- Hero banner outil -->
  {brand && (
    <div class="w-full py-10 sm:py-14 px-4 relative overflow-hidden" style={`background: ${brand.gradient};`}>
      <div class="absolute inset-0 opacity-10" style="background-image: linear-gradient(white 1px, transparent 1px), linear-gradient(to right, white 1px, transparent 1px); background-size: 40px 40px;"></div>
      <div class="max-w-3xl mx-auto text-center relative">
        {brand.logoFile ? (
          <img src={brand.logoFile} alt={`Logo ${outil.data.outil}`} class="w-14 h-14 sm:w-20 sm:h-20 mx-auto mb-4 object-contain" loading="eager" />
        ) : brand.svgPath ? (
          <svg class="w-12 h-12 sm:w-16 sm:h-16 mx-auto mb-4" viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
            <path d={brand.svgPath} />
          </svg>
        ) : (
          <div class="w-16 h-16 sm:w-20 sm:h-20 mx-auto mb-4 rounded-2xl bg-white/15 backdrop-blur-sm flex items-center justify-center">
            <span class="text-3xl sm:text-4xl font-display font-bold" style={`color: ${brand.textColor};`}>{outil.data.outil[0]}</span>
          </div>
        )}
        <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-3" style={`color: ${brand.textColor};`}>{outil.data.outil}</h1>
        <p class="text-base sm:text-lg opacity-80" style={`color: ${brand.textColor};`}>{brand.tagline}</p>
        {outil.data.rating && (
          <div class="mt-4 inline-flex items-center gap-1.5 bg-white/20 backdrop-blur-sm px-3 py-1.5 rounded-full">
            <span class="text-sm font-bold" style={`color: ${brand.textColor};`}>{outil.data.rating}/10</span>
            <span class="text-xs opacity-70" style={`color: ${brand.textColor};`}>notre verdict</span>
          </div>
        )}
        {aff && (
          <div class="mt-5">
            <a href={aff.url} target="_blank" rel="noopener noreferrer sponsored" class="inline-flex items-center gap-2 bg-white font-bold px-6 py-3 rounded-full text-sm transition-all hover:scale-[1.03] active:scale-[0.98] shadow-lg" style={`color: ${brand.gradient.includes('#10A37F') ? '#10A37F' : brand.gradient.includes('#D4A574') ? '#B8860B' : '#1a1a2e'};`}>
              {aff.cta}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
            </a>
          </div>
        )}
      </div>
    </div>
  )}

  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
    <Breadcrumbs items={breadcrumbs} />

    <header class="mb-8 sm:mb-10">
      <div class="flex items-center gap-3 mb-3">
        <span class="text-xs font-medium text-primary uppercase tracking-wide">{outil.data.category}</span>
      </div>
      {!brand && <h1 class="mb-4">{outil.data.title}</h1>}
      <div class="flex flex-wrap items-center gap-3 sm:gap-4 text-gray-500 text-xs sm:text-sm">
        <span>{outil.data.author || siteConfig.blog.defaultAuthor}</span>
        <span>·</span>
        <time datetime={dateStr}>
          {outil.data.date.toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}
        </time>
        <span>·</span>
        <span class="font-medium">{outil.data.pricing}</span>
      </div>
    </header>

    <div class="prose max-w-none">
      <Content />
    </div>

    <!-- CTA affilié -->
    {aff && (
      <div class="mt-10 p-5 sm:p-6 rounded-2xl text-center" style={`background: linear-gradient(135deg, ${siteConfig.colors.primary}08, ${siteConfig.colors.accent}08);`}>
        <p class="font-bold text-base sm:text-lg mb-2">{outil.data.outil}</p>
        {aff.note && <p class="text-gray-500 text-sm mb-4">{aff.note}</p>}
        <a
          href={aff.url}
          target="_blank"
          rel="noopener noreferrer sponsored"
          class="inline-flex items-center gap-2 text-white font-bold px-6 sm:px-8 py-3 sm:py-3.5 rounded-full text-sm sm:text-base transition-all hover:scale-[1.03] active:scale-[0.98]"
          style={`background: ${siteConfig.colors.primary}; box-shadow: 0 2px 4px 0 rgba(255,255,255,0.3) inset, 0 4px 12px -2px rgba(230,57,70,0.3);`}
        >
          {aff.cta}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
        </a>
        <p class="text-[10px] text-gray-400 mt-3">Lien affilié : si tu t'inscris via ce lien, Adapte-toi perçoit une commission. Ça ne change ni le prix ni notre avis.</p>
      </div>
    )}

    <!-- Maillage interne -->
    <div class="mt-12 p-5 sm:p-6 bg-gray-50 rounded-2xl">
      <p class="font-bold text-base sm:text-lg mb-4">Utilise cet outil dans ton métier</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <a href="/metiers" class="flex items-center gap-3 p-3 bg-white rounded-xl border border-gray-100 hover:border-primary/30 transition-colors text-sm">
          <span class="text-lg">📊</span>
          <span class="text-gray-700 font-medium">Fiches métier (quel impact IA ?)</span>
        </a>
        <a href="/guides/prompt-engineering-debutant" class="flex items-center gap-3 p-3 bg-white rounded-xl border border-gray-100 hover:border-primary/30 transition-colors text-sm">
          <span class="text-lg">💡</span>
          <span class="text-gray-700 font-medium">Apprendre le prompt engineering</span>
        </a>
        <a href="/guides/automatiser-travail-ia" class="flex items-center gap-3 p-3 bg-white rounded-xl border border-gray-100 hover:border-primary/30 transition-colors text-sm">
          <span class="text-lg">⚡</span>
          <span class="text-gray-700 font-medium">Automatiser ton travail</span>
        </a>
        <a href="/guides/se-former-ia-gratuitement" class="flex items-center gap-3 p-3 bg-white rounded-xl border border-gray-100 hover:border-primary/30 transition-colors text-sm">
          <span class="text-lg">🎓</span>
          <span class="text-gray-700 font-medium">Se former gratuitement</span>
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
