---
import BaseLayout from "../layouts/BaseLayout.astro";
import DiagnosticQuiz from "../components/DiagnosticQuiz.astro";
import { siteConfig } from "../../site.config";
import { glossaire, glossaireAliases, type GlossaireEntry } from "../data/glossaire";
import { linkifyDefinition, slugifyTerm } from "../utils/glossaire";

// 3 termes aléatoires différents à chaque build pour un 404 vivant
const entries = Object.entries(glossaire) as Array<[string, GlossaireEntry]>;
const shuffled = [...entries].sort(() => Math.random() - 0.5);
const microLesson = shuffled.slice(0, 3);

const slugify = slugifyTerm;
---

<BaseLayout title={`Page introuvable | ${siteConfig.name}`} description="Cette page n'existe pas." noIndex>
  <div class="max-w-3xl mx-auto px-4 py-12 md:py-16 text-center">
    <!-- Header 404 animé -->
    <p class="text-[120px] md:text-[180px] font-display font-bold leading-none mb-2 blur-reveal select-none" style={`color: ${siteConfig.colors.primary}12; letter-spacing: -0.05em;`}>404</p>
    <h1 class="text-2xl md:text-3xl mb-3 -mt-10 blur-reveal" style="animation-delay: 0.1s;">Cette page n'existe pas</h1>
    <p class="text-gray-500 mb-8 blur-reveal" style="animation-delay: 0.2s;">
      Comme 27% des emplois français d'ici 2030, elle a peut-être été remplacée.
      <br class="hidden sm:block" />Mais toi, tu peux encore t'adapter.
    </p>

    <div class="mb-10">
      <DiagnosticQuiz />
    </div>

    <!-- Nav links -->
    <div class="flex flex-col sm:flex-row gap-3 justify-center fade-up">
      <a href="/" class="inline-flex items-center gap-2 text-white font-semibold px-6 py-3 rounded-full transition-all hover:scale-[1.03] active:scale-[0.98]" style={`background: ${siteConfig.colors.primary}; box-shadow: 0 2px 4px 0 rgba(255,255,255,0.3) inset;`}>
        Retour à l'accueil
      </a>
      <a href="/metiers" class="inline-flex items-center gap-2 text-gray-700 font-semibold px-6 py-3 rounded-full border-2 border-gray-200 hover:border-primary/30 hover:text-primary transition-all">
        Explorer les métiers
      </a>
    </div>

    <!-- Micro-leçon glossaire : puisque tu es là -->
    <section class="mt-16 text-left fade-up" style="animation-delay: 0.35s;">
      <div class="flex items-center justify-between mb-6">
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-primary">Puisque tu es là</p>
          <h2 class="text-xl sm:text-2xl font-display font-bold mt-1">3 mots IA à retenir avant de partir</h2>
        </div>
        <a href="/glossaire" class="text-sm text-secondary font-semibold hover:text-primary whitespace-nowrap">
          Tout le glossaire →
        </a>
      </div>
      <div class="grid sm:grid-cols-3 gap-4">
        {microLesson.map(([key, entry]) => (
          <a
            href={`/glossaire#${slugify(key)}`}
            class="group block bg-white rounded-xl border border-gray-100 p-5 hover:border-primary/30 hover:shadow-md transition-all"
          >
            <div class="text-[10px] font-bold uppercase tracking-wider text-primary mb-2">{entry.category}</div>
            <h3 class="text-base font-bold mb-2 capitalize group-hover:text-primary transition-colors">{key}</h3>
            <p class="text-gray-600 text-sm leading-snug line-clamp-3 mb-3" set:html={linkifyDefinition(entry.definition, glossaire, glossaireAliases, key, 3, "glossaire-card-link")}></p>
            <p class="text-gray-500 text-xs leading-snug bg-gray-50 border-l-2 border-accent rounded-r px-2.5 py-1.5 line-clamp-3">
              <strong class="text-accent">Ex.</strong> <span set:html={linkifyDefinition(entry.example, glossaire, glossaireAliases, key, 2, "glossaire-card-link")}></span>
            </p>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

