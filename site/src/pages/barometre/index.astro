---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { siteConfig } from "../../../site.config";

const title = "Baromètre IA et travail : chiffres vérifiés de juillet 2026 | Adapte-toi";
const description = "Les chiffres vérifiés sur l'usage de l'IA au travail en France et dans le monde, avec périmètre, source primaire et date de mise à jour.";
const releaseDate = "2026-07-21";
const bcgFr = "https://www.bcg.com/press/3june2026-ia-au-travail-jusqua-une-journee-economisee-par-semaine";
const bcgGlobal = "https://www.bcg.com/press/3june2026-ai-reshaping-jobs-faster-than-companies-reshaping-work";

const indicators = [
  { label: "Usage régulier en France", value: 62, unit: "%", scope: "Salariés français interrogés", color: siteConfig.colors.primary },
  { label: "Une journée gagnée en France", value: 20, unit: "%", scope: "Utilisateurs réguliers en France", color: siteConfig.colors.accent },
  { label: "Peu ou pas de consignes", value: 66, unit: "%", scope: "Utilisateurs réguliers, monde", color: siteConfig.colors.secondary },
  { label: "Charge cognitive accrue", value: 41, unit: "%", scope: "Utilisateurs réguliers, monde", color: "#7C3AED" },
];

const findings = [
  { value: "11 749", label: "personnes interrogées", note: "Dirigeants, managers et employés dans 14 marchés." },
  { value: "74 %", label: "d'usage régulier en première ligne", note: "Employés non-managers, contre 51 % en 2025." },
  { value: "47 %", label: "pilotent davantage l'IA", note: "Ils passent plus de temps à diriger l'IA qu'à exécuter eux-mêmes le travail." },
  { value: "67 %", label: "plus satisfaits au travail", note: "Un résultat à lire avec les 41 % qui signalent aussi davantage de charge cognitive." },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Dataset",
  name: "Baromètre Adapte-toi IA et travail, juillet 2026",
  description,
  creator: { "@type": "NewsMediaOrganization", name: siteConfig.name, url: siteConfig.url },
  datePublished: releaseDate,
  dateModified: releaseDate,
  isBasedOn: [bcgFr, bcgGlobal],
  measurementTechnique: "Reprise éditoriale de résultats publiés par BCG, sans extrapolation ni indice propriétaire.",
  variableMeasured: indicators.map((item) => ({ "@type": "PropertyValue", name: item.label, value: item.value, unitText: item.unit })),
  temporalCoverage: "2026",
  spatialCoverage: [{ "@type": "Country", name: "France" }, { "@type": "Place", name: "14 marchés mondiaux" }],
};

const breadcrumbs = [
  { name: "Accueil", url: siteConfig.url },
  { name: "Baromètre", url: `${siteConfig.url}/barometre/` },
];
---

<BaseLayout title={title} description={description} canonicalUrl={`${siteConfig.url}/barometre/`} jsonLd={jsonLd}>
  <div class="max-w-5xl mx-auto px-4 py-10 md:py-16">
    <Breadcrumbs items={breadcrumbs} />

    <header class="mb-10 md:mb-14">
      <div class="flex flex-wrap items-center gap-2 mb-4">
        <span class="inline-flex items-center gap-1.5 text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full bg-primary/10 text-primary">
          <span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
          Édition vérifiée · Juillet 2026
        </span>
        <span class="text-xs text-gray-500">Mise à jour : 21 juillet 2026</span>
      </div>
      <h1 class="text-3xl md:text-5xl mb-4" data-speakable>IA et travail : les chiffres, sans faux suspense</h1>
      <p class="text-lg text-gray-600 leading-relaxed max-w-3xl" data-speakable>
        Cette édition abandonne l'ancien indice propriétaire insuffisamment documenté. Elle présente uniquement des résultats reliés à leur source primaire, avec leur population et leur périmètre.
      </p>
    </header>

    <section class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-5 mb-14" aria-label="Indicateurs clés">
      {indicators.map((item) => (
        <div class="bg-white rounded-xl border border-gray-100 p-5 shadow-sm">
          <div class="text-[10px] font-bold uppercase tracking-widest text-gray-600 mb-2">{item.label}</div>
          <div class="flex items-baseline gap-1">
            <span class="text-3xl md:text-4xl font-display font-bold" style={`color: ${item.color};`}>{item.value}</span>
            <span class="text-lg font-semibold text-gray-500">{item.unit}</span>
          </div>
          <p class="text-xs text-gray-600 mt-3 leading-relaxed">{item.scope}</p>
        </div>
      ))}
    </section>

    <section class="mb-14">
      <h2 class="text-2xl font-display font-bold mb-2">Ce que mesure vraiment l'étude</h2>
      <p class="text-sm text-gray-600 mb-6">BCG AI at Work 2026 est une enquête déclarative : elle mesure des usages et perceptions, pas une productivité observée par un employeur.</p>
      <div class="grid sm:grid-cols-2 gap-4">
        {findings.map((finding) => (
          <article class="bg-gray-50 rounded-xl border border-gray-100 p-5">
            <p class="text-2xl font-display font-bold text-primary">{finding.value}</p>
            <h3 class="font-semibold mt-1">{finding.label}</h3>
            <p class="text-sm text-gray-600 mt-2">{finding.note}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="mb-14 bg-secondary text-white rounded-2xl p-6 md:p-10">
      <h2 class="text-2xl font-display font-bold text-white mb-3">La lecture utile</h2>
      <div class="space-y-3 text-gray-200 leading-relaxed">
        <p>La France adopte l'IA, mais transforme encore peu le temps gagné en nouvelle organisation du travail.</p>
        <p>Un gain individuel ne devient pas automatiquement un gain collectif. Sans règles, formation et redéfinition des tâches, il peut simplement augmenter le volume et la complexité du travail.</p>
        <p>Pour un salarié, la priorité est donc de documenter ses usages, vérifier les résultats et développer les compétences de supervision que les outils ne prennent pas en charge.</p>
      </div>
    </section>

    <section class="mb-14">
      <h2 class="text-2xl font-display font-bold mb-4">Sources et méthode</h2>
      <div class="prose prose-sm max-w-none text-gray-700 space-y-4">
        <p><strong>Source primaire France :</strong> <a href={bcgFr} rel="noopener" class="text-primary font-semibold">BCG, « IA au travail : jusqu'à une journée économisée par semaine », 3 juin 2026</a>.</p>
        <p><strong>Source primaire internationale :</strong> <a href={bcgGlobal} rel="noopener" class="text-primary font-semibold">BCG, « AI Is Reshaping Jobs Faster Than Companies Are Reshaping Work », 3 juin 2026</a>.</p>
        <p><strong>Méthode Adapte-toi :</strong> transcription des résultats publiés par BCG, séparation des chiffres France et monde, vérification du dénominateur et suppression de toute extrapolation propriétaire. Aucune moyenne n'a été recalculée.</p>
        <p><strong>Limite :</strong> les données sont déclaratives. Elles ne prouvent ni le temps réellement économisé ni un lien causal entre l'IA et la satisfaction au travail.</p>
      </div>
    </section>

    <section class="bg-gray-50 rounded-2xl p-6 md:p-10 border border-gray-100">
      <h2 class="text-xl font-display font-bold mb-3">Une erreur ou une source plus récente ?</h2>
      <p class="text-gray-700">
        Écris à <a href="mailto:contact@adapte-toi.com?subject=Correction%20baromètre" class="text-primary font-semibold">contact@adapte-toi.com</a>. Toute correction factuelle validée est datée selon notre <a href="/politique-de-correction/" class="text-primary font-semibold">politique de correction</a>.
      </p>
    </section>
  </div>
</BaseLayout>
