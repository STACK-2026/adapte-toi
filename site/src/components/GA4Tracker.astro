---
// GA4 tracker — runs ALONGSIDE the existing Supabase tracker (Mix mode).
// Same consent gate as Analytics.astro: respects `adaptetoi_consent=declined` cookie.
const GA4_ID = "G-7B0HL2ZGFK";
---

<script define:vars={{ GA4_ID }}>
  (function () {
    const consent = document.cookie.match(/adaptetoi_consent=([^;]+)/);
    if (consent && consent[1] === "declined") return;

    const s = document.createElement("script");
    s.async = true;
    s.src = "https://www.googletagmanager.com/gtag/js?id=" + GA4_ID;
    document.head.appendChild(s);

    window.dataLayer = window.dataLayer || [];
    function gtag() {
      window.dataLayer.push(arguments);
    }
    window.gtag = gtag;
    gtag("js", new Date());
    gtag("config", GA4_ID);
  })();
</script>
