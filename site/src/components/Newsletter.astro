---
import { siteConfig } from "../../site.config";
---

<section class="py-20 px-4">
  <div
    class="max-w-4xl mx-auto rounded-2xl p-10 md:p-14 text-center"
    style={`background: linear-gradient(135deg, ${siteConfig.colors.secondary}, ${siteConfig.colors.secondary}dd);`}
  >
    <h2 class="text-white mb-4 fade-up">Le Signal - Newsletter hebdomadaire</h2>
    <p class="text-gray-300 text-lg mb-8 max-w-xl mx-auto fade-up">
      Chaque lundi, l'essentiel de l'impact de l'IA sur l'emploi. Les chiffres, les tendances, les actions concrètes. En 5 minutes.
    </p>

    <form id="newsletter-form" class="max-w-md mx-auto flex flex-col sm:flex-row gap-3 fade-up">
      <input
        type="email"
        name="email"
        required
        placeholder="ton@email.com"
        class="flex-1 px-5 py-3 rounded-xl text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-accent"
      />
      <button
        type="submit"
        class="font-semibold px-6 py-3 rounded-xl text-white transition-all hover:scale-105 hover:shadow-md"
        style={`background: ${siteConfig.colors.primary};`}
      >
        S'abonner
      </button>
    </form>

    <p id="newsletter-msg" class="text-gray-400 text-xs mt-4 fade-up"></p>
    <p class="text-gray-400 text-xs mt-2 fade-up">
      Pas de spam, pas de revente. Désinscription en un clic.
    </p>
  </div>
</section>

<script>
  const form = document.getElementById("newsletter-form");
  const msg = document.getElementById("newsletter-msg");
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const email = new FormData(form as HTMLFormElement).get("email");
    if (!email) return;
    try {
      const r = await fetch("https://commbksqnwhpsyenjzuf.supabase.co/rest/v1/newsletter_subscribers", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "apikey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNvbW1ia3NxbndocHN5ZW5qenVmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYwNzM3MjUsImV4cCI6MjA5MTY0OTcyNX0.6igBrd7TAiC5CamU5hmHfEd-JBb4MJuvGAyGHo6tJpU",
          "Authorization": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNvbW1ia3NxbndocHN5ZW5qenVmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYwNzM3MjUsImV4cCI6MjA5MTY0OTcyNX0.6igBrd7TAiC5CamU5hmHfEd-JBb4MJuvGAyGHo6tJpU",
          "Prefer": "return=minimal",
        },
        body: JSON.stringify({ email, source: "homepage" }),
      });
      if (r.ok) {
        if (msg) msg.textContent = "Bienvenue à bord. Tu recevras Le Signal dès lundi prochain.";
        (form as HTMLFormElement).reset();
      } else if (r.status === 409) {
        if (msg) msg.textContent = "Tu es déjà inscrit. On se retrouve lundi.";
      } else {
        if (msg) msg.textContent = "Erreur. Réessaie dans quelques instants.";
      }
    } catch {
      if (msg) msg.textContent = "Erreur réseau. Réessaie.";
    }
  });
</script>
