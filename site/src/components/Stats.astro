---
const stats = [
  { value: "27%", label: "des emplois français menacés", source: "OCDE", detail: "Soit plus de 4 millions de postes exposés à un risque d'automatisation élevé d'ici 2030." },
  { value: "93%", label: "des métiers impactés par l'IA", source: "Cognizant 2026", detail: "La quasi-totalité des professions sera transformée par l'IA générative dès cette année." },
  { value: "47%", label: "des actifs envisagent une reconversion", source: "Ipsos", detail: "Près d'un actif français sur deux pense à changer de métier face à l'IA." },
  { value: "+270%", label: "de croissance des offres IA", source: "LinkedIn", detail: "Les offres mentionnant l'IA ont été multipliées par presque 4 entre 2019 et 2024." },
  { value: "30%", label: "des heures automatisables d'ici 2030", source: "McKinsey", detail: "Près d'un tiers des heures travaillées pourrait être automatisé par l'IA générative." },
  { value: "+25%", label: "de salaire pour les profils IA-ready", source: "PwC", detail: "Les professionnels qui maîtrisent les outils IA gagnent 25% de plus en moyenne." },
];
---

<section class="py-24 px-4">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-center mb-4 blur-reveal">Les chiffres qui comptent</h2>
    <p class="text-center text-gray-500 mb-14 max-w-xl mx-auto blur-reveal">
      Pas d'opinions, pas de spéculation. Que des données sourcées. Clique pour en savoir plus.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 sm:gap-6 stagger-children">
      {stats.map((stat) => (
        <button
          class="stat-card text-center p-5 sm:p-6 md:p-8 rounded-xl sm:rounded-2xl bg-white border border-gray-100 shadow-sm hover-glow cursor-pointer transition-all"
          data-detail={stat.detail}
        >
          <p class="font-display font-bold text-4xl sm:text-3xl md:text-5xl mb-1 sm:mb-2" style="color: var(--color-primary);" data-count={stat.value}>
            0
          </p>
          <p class="text-gray-700 font-medium text-sm mb-1">{stat.label}</p>
          <p class="text-xs text-gray-400">{stat.source}</p>
          <div class="expand-content mt-3" data-expand>
            <div>
              <p class="text-xs text-gray-500 leading-relaxed pt-3 border-t border-gray-100">{stat.detail}</p>
            </div>
          </div>
        </button>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll(".stat-card").forEach((card) => {
    card.addEventListener("click", () => {
      const expand = card.querySelector("[data-expand]");
      if (expand) expand.classList.toggle("expanded");
    });
  });
</script>
