---
import { siteConfig } from "../../site.config";
import TextMorph from "./TextMorph.astro";
import G from "./Glossaire.astro";

// Phrases courtes pour que le TextMorph ne coupe pas sur mobile
const heroPhrasesLine2 = [
  "Toi aussi, change.",
  "Adapte-toi maintenant.",
  "Ton métier va changer.",
  "L'IA n'attend pas.",
  "Il est temps d'agir.",
  "Ne reste pas passif.",
  "Anticipe. Adapte. Avance.",
];

const ctaPhrases = [
  "Fais le diagnostic",
  "Évalue ton risque",
  "Teste gratuitement",
];
---

<section class="relative overflow-hidden py-16 sm:py-24 md:py-36 px-4">
  <!-- Animated gradient background -->
  <div class="absolute inset-0 gradient-animated opacity-[0.04]" style="background: linear-gradient(135deg, #E63946, #F77F00, #1D3557, #E63946);"></div>
  <!-- Subtle grid (visible sur mobile aussi, plus fin) -->
  <div class="absolute inset-0 opacity-[0.02] sm:opacity-[0.025]" style="background-image: linear-gradient(#1D3557 1px, transparent 1px), linear-gradient(to right, #1D3557 1px, transparent 1px); background-size: 35px 35px;"></div>
  <!-- Fondu haut et bas -->
  <div class="absolute top-0 left-0 right-0 h-20 bg-gradient-to-b from-[#fafbfc] to-transparent"></div>
  <div class="absolute bottom-0 left-0 right-0 h-20 bg-gradient-to-t from-[#fafbfc] to-transparent"></div>

  <div class="max-w-4xl mx-auto text-center relative">
    <!-- Badge urgence - plus compact sur mobile -->
    <div class="inline-flex items-center gap-2 bg-primary/8 text-primary text-xs sm:text-sm font-semibold px-3 sm:px-4 py-1.5 rounded-full mb-6 sm:mb-10 scale-reveal">
      <span class="w-1.5 h-1.5 sm:w-2 sm:h-2 bg-primary rounded-full pulse-signal"></span>
      <span class="hidden sm:inline">47% des Français actifs envisagent une reconversion (Ipsos 2026)</span>
      <span class="sm:hidden">47% des Français actifs envisagent une reconversion</span>
    </div>

    <!-- H1 - sizing adapté mobile -->
    <h1 class="mb-6 sm:mb-8 text-[1.75rem] sm:text-[2.5rem] md:text-[3.5rem] leading-[1.1]" data-speakable>
      <span data-split-words class="block">Le monde du travail change.</span>
      <span class="block mt-1 sm:mt-2" style={`color: ${siteConfig.colors.primary};`}>
        <TextMorph
          phrases={heroPhrasesLine2}
          interval={3200}
          class="font-display font-bold"
        />
      </span>
    </h1>

    <p class="text-base sm:text-lg md:text-xl text-gray-500 max-w-2xl mx-auto mb-8 sm:mb-12 blur-reveal leading-relaxed px-2" data-speakable>
      L'<G term="intelligence artificielle" display="IA" /> transforme chaque métier. Certains disparaissent, d'autres se réinventent. Adapte-toi t'aide à comprendre et à agir.
    </p>

    <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center fade-up px-4 sm:px-0">
      <a
        href="/metiers"
        class="group inline-flex items-center justify-center gap-2 text-white font-bold px-6 sm:px-8 py-4 sm:py-4 rounded-full text-base sm:text-lg transition-all hover:scale-[1.03] hover:shadow-xl active:scale-[0.97] w-full sm:w-auto"
        style={`background: ${siteConfig.colors.primary}; box-shadow: 0 2px 4px 0 rgba(255,255,255,0.3) inset, 0 4px 12px -2px rgba(230,57,70,0.3);`}
      >
        <TextMorph
          phrases={ctaPhrases}
          interval={4000}
          class="font-bold"
        />
        <svg class="w-5 h-5 transition-transform group-hover:translate-x-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a
        href="/guides"
        class="inline-flex items-center justify-center gap-2 text-gray-700 font-bold px-6 sm:px-8 py-4 sm:py-4 rounded-full text-base sm:text-lg border-2 border-gray-300 hover:border-primary/30 hover:text-primary transition-all active:scale-[0.97] w-full sm:w-auto"
      >
        Guides de reconversion
        <svg class="w-4 h-4 flex-shrink-0 sm:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
      </a>
    </div>

    <!-- Trust indicators -->
    <div class="flex flex-wrap justify-center gap-3 sm:gap-6 mt-10 sm:mt-14 text-xs sm:text-sm text-gray-400 fade-up" data-parallax="0.03">
      <span>OCDE · McKinsey · Anthropic · FMI</span>
      <span class="hidden sm:inline">·</span>
      <span>100% indépendant</span>
      <span class="hidden sm:inline">·</span>
      <span class="hidden sm:inline">Zéro formation à vendre</span>
    </div>
  </div>
</section>
