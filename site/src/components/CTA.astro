---
import { siteConfig } from "../../site.config";
---

<section class="py-20 px-4">
  <div
    class="max-w-4xl mx-auto text-center text-white rounded-2xl p-12 md:p-16 relative overflow-hidden"
    style={`background: ${siteConfig.colors.primary};`}
  >
    <!-- Grid pattern overlay -->
    <div class="absolute inset-0 opacity-10" style="background-image: linear-gradient(white 1px, transparent 1px), linear-gradient(to right, white 1px, transparent 1px); background-size: 30px 30px;"></div>

    <div class="relative">
      <h2 class="text-white mb-4 fade-up">Le monde change. Toi aussi.</h2>
      <p class="text-white/80 text-lg mb-8 max-w-xl mx-auto fade-up">
        N'attends pas que ton poste disparaisse pour reagir. Explore nos fiches metier, lis nos guides, et commence ta transformation des aujourd'hui.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center fade-up">
        <a
          href="/metiers"
          class="inline-flex items-center gap-2 bg-white font-bold px-8 py-4 rounded-xl text-lg transition-all hover:scale-105 hover:shadow-lg"
          style={`color: ${siteConfig.colors.primary};`}
        >
          Explorer les metiers
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a
          href="/newsletter"
          class="inline-flex items-center gap-2 border-2 border-white/50 text-white font-bold px-8 py-4 rounded-xl text-lg transition-all hover:bg-white/10"
        >
          Recevoir Le Signal
        </a>
      </div>
    </div>
  </div>
</section>
