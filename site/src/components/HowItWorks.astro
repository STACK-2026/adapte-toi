---
import { siteConfig } from "../../site.config";
import G from "./Glossaire.astro";

const steps = [
  {
    num: "01",
    title: "Identifie ton risque",
    description: "Consulte la fiche de ton métier pour comprendre comment l'intelligence artificielle l'impacte concrètement. Pas de panique, juste des faits.",
    link: "/metiers",
    cta: "Explorer les métiers",
    color: siteConfig.colors.primary,
  },
  {
    num: "02",
    title: "Forme-toi stratégiquement",
    description: "Nos guides te montrent exactement quelles compétences acquérir, quels outils maîtriser, et comment financer ta formation.",
    link: "/guides",
    cta: "Lire les guides",
    color: siteConfig.colors.accent,
  },
  {
    num: "03",
    title: "Passe à l'action",
    description: "Outils IA par métier, témoignages de reconvertis, plans d'action concrets. Tu as tout ce qu'il faut pour bouger.",
    link: "/outils",
    cta: "Découvrir les outils",
    color: siteConfig.colors.secondary,
  },
];
---

<section class="py-24 px-4">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-center mb-4 blur-reveal">Comment ça marche</h2>
    <p class="text-center text-gray-500 mb-16 max-w-xl mx-auto blur-reveal">
      Trois étapes pour reprendre le contrôle de ta carrière.
    </p>

    <div class="space-y-16">
      {steps.map((step, i) => (
        <div class={`flex flex-col md:flex-row items-center gap-10 ${i % 2 === 1 ? "md:flex-row-reverse" : ""} ${i % 2 === 0 ? "slide-left" : "slide-right"}`}>
          <div class="flex-shrink-0">
            <div
              class="w-20 h-20 rounded-2xl flex items-center justify-center font-display font-bold text-3xl text-white shadow-lg"
              style={`background: ${step.color};`}
            >
              {step.num}
            </div>
          </div>
          <div class="flex-1 text-center md:text-left">
            <h3 class="text-2xl font-bold mb-3">{step.title}</h3>
            <p class="text-gray-600 text-lg mb-5 leading-relaxed">{step.description}</p>
            <a
              href={step.link}
              class="inline-flex items-center gap-2 font-semibold hover:gap-3 transition-all"
              style={`color: ${step.color};`}
            >
              {step.cta}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
