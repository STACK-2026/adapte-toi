---
import { siteConfig } from "../../site.config";
---

<header id="site-header" class="fixed top-0 left-0 right-0 w-full z-50 bg-white/95 backdrop-blur-xl border-b border-gray-200/50 transition-transform duration-500 ease-in-out">
  <!-- Alert bar - modern gradient banner -->
  <a href="/guides/reconversion-ia-guide-complet" class="block w-full slide-in-top group" style="background: linear-gradient(90deg, #1D3557, #2a4a7f, #1D3557); min-width: 100%;">
    <div class="flex items-center justify-between py-1.5 sm:py-2 px-4 sm:px-6 text-white">
      <div class="flex items-center gap-2">
        <span class="relative flex h-2 w-2 flex-shrink-0">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
        </span>
        <span class="text-[10px] sm:text-xs font-medium tracking-wide">
          <span class="hidden sm:inline"><strong class="text-accent">27%</strong> des emplois français menacés par l'IA d'ici 2030</span>
          <span class="sm:hidden"><strong class="text-accent">27%</strong> des emplois menacés par l'IA</span>
        </span>
      </div>
      <span class="text-[10px] sm:text-xs font-semibold text-white/90 group-hover:text-accent transition-colors whitespace-nowrap flex-shrink-0">Que faire ? &rarr;</span>
    </div>
  </a>

  <nav class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 font-display font-800 text-xl tracking-tight" style={`color: ${siteConfig.colors.primary};`}>
      <!-- Signal bars icon -->
      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <rect class="signal-bar" x="2" y="16" width="4" height="6" rx="1" fill={siteConfig.colors.primary}/>
        <rect class="signal-bar" x="8" y="10" width="4" height="12" rx="1" fill={siteConfig.colors.accent}/>
        <rect class="signal-bar" x="14" y="6" width="4" height="16" rx="1" fill={siteConfig.colors.primary}/>
        <rect class="signal-bar" x="20" y="2" width="4" height="20" rx="1" fill={siteConfig.colors.secondary}/>
      </svg>
      {siteConfig.name}
    </a>

    <!-- Desktop nav -->
    <ul class="hidden lg:flex items-center gap-6">
      {siteConfig.navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-sm font-medium text-gray-600 hover:text-primary transition-colors"
            {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA newsletter desktop -->
    <a
      href="/newsletter"
      class="hidden lg:inline-flex items-center gap-2 text-sm font-semibold text-white px-5 py-2 rounded-lg transition-all hover:scale-105 hover:shadow-md"
      style={`background: ${siteConfig.colors.primary};`}
    >
      S'abonner
    </a>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden p-2 text-gray-600"
      aria-label="Menu"
      aria-expanded="false"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu - flottant, glass, coins arrondis (style ScoreImmo) -->
  <div id="mobile-menu" class="lg:hidden hidden fixed top-[calc(var(--header-h,88px))] left-3 right-3 z-50">
    <div class="bg-white/95 backdrop-blur-xl rounded-2xl shadow-2xl border border-gray-200/60 overflow-hidden">
      <ul class="px-2 py-3 space-y-0.5">
        {siteConfig.navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="flex items-center gap-3 text-gray-700 font-medium py-3 px-4 rounded-xl hover:bg-gray-50 active:bg-gray-100 transition-colors"
              {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
            >
              {link.label}
              <svg class="w-4 h-4 ml-auto text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </a>
          </li>
        ))}
      </ul>
      <div class="px-4 pb-4 pt-2">
        <a
          href="/newsletter"
          class="block text-center text-white font-bold py-3.5 rounded-xl transition-all active:scale-[0.98]"
          style={`background: ${siteConfig.colors.primary}; box-shadow: 0 2px 4px 0 rgba(255,255,255,0.3) inset;`}
        >
          S'abonner à la newsletter
        </a>
      </div>
    </div>
  </div>
  <!-- Backdrop overlay -->
  <div id="mobile-menu-backdrop" class="lg:hidden hidden fixed inset-0 bg-black/20 backdrop-blur-sm z-40" style="top: var(--header-h, 88px);"></div>
</header>

<!-- Spacer for fixed header (alert bar + nav) -->
<div class="h-[88px]"></div>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const backdrop = document.getElementById("mobile-menu-backdrop");

  function toggleMenu() {
    const open = menu?.classList.toggle("hidden") === false;
    backdrop?.classList.toggle("hidden", !open);
    btn?.setAttribute("aria-expanded", String(open));
  }

  btn?.addEventListener("click", toggleMenu);
  backdrop?.addEventListener("click", toggleMenu);

  // Close menu on link click
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.add("hidden");
      backdrop?.classList.add("hidden");
      btn?.setAttribute("aria-expanded", "false");
    });
  });

  let lastY = 0;
  const header = document.getElementById("site-header");
  window.addEventListener("scroll", () => {
    const y = window.scrollY;
    if (y > 120 && y > lastY) {
      header?.classList.add("-translate-y-full");
    } else {
      header?.classList.remove("-translate-y-full");
    }
    lastY = y;
  }, { passive: true });
</script>
