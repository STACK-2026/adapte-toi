---
import { siteConfig } from "../../site.config";
import G from "./Glossaire.astro";

const iconMap: Record<string, string> = {
  zap: "M13 10V3L4 14h7v7l9-11h-7z",
  shield: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z",
  chart: "M18 20V10M12 20V4M6 20v-6",
  search: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z",
  users: "M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8zm14 10v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75",
  star: "M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z",
};

const featureLinks: Record<string, string> = {
  "Fiches métier IA": "/metiers",
  "Guides pratiques": "/guides",
  "Annuaire d'outils IA": "/outils",
  "Veille hebdomadaire": "/blog",
  "Diagnostic personnalisé": "/diagnostic",
  "Baromètre mensuel": "/barometre",
};
---

<section class="py-20 px-4 bg-gray-50">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-center mb-4 fade-up">Ce que tu trouves sur Adapte-toi</h2>
    <p class="text-center text-gray-500 mb-12 max-w-xl mx-auto fade-up">
      Pas de blabla, pas de formation à 1 500 euros. De l'information concrète et gratuite.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-8 stagger-children">
      {siteConfig.features.map((feature, i) => (
        <a
          href={featureLinks[feature.title] || "#"}
          class="flex sm:block items-start gap-4 sm:gap-0 bg-white rounded-xl sm:rounded-2xl p-4 sm:p-8 shadow-sm hover-glow transition-all active:scale-[0.98] hover:-translate-y-1 border border-gray-100"
        >
          <div
            class="w-10 h-10 sm:w-12 sm:h-12 rounded-lg sm:rounded-xl flex items-center justify-center flex-shrink-0 sm:mb-5"
            style={`background: ${siteConfig.colors.primary}10;`}
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke={siteConfig.colors.primary}
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d={iconMap[feature.icon] || iconMap.zap} />
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="text-base sm:text-lg font-bold mb-1 sm:mb-2">{feature.title}</h3>
            <p class="text-gray-600 text-xs sm:text-sm line-clamp-2 sm:line-clamp-none">{feature.description}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
